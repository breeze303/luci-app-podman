#!/bin/sh /etc/rc.common

USE_PROCD=1
START=95
STOP=10

SERVICE_BIN="/usr/bin/podman"
SERVICE_URI="unix:///run/podman/podman.sock"
SERVICE_SOCKET="/run/podman/podman.sock"
SERVICE_PIDFILE="/var/run/luci-podman-service.pid"
RECONCILE_HELPER="/usr/libexec/luci-podman-reconcile"

EXTRA_COMMANDS="probe"
EXTRA_HELP="\n\tprobe\tReport luci-podman service/socket state"

service_is_running() {
	local pid

	[ -f "$SERVICE_PIDFILE" ] || return 1
	read -r pid <"$SERVICE_PIDFILE"
	[ -n "$pid" ] || return 1
	[ -d "/proc/$pid" ]
}

socket_exists() {
	[ -S "$SERVICE_SOCKET" ]
}

service_healthy() {
	"$SERVICE_BIN" --url "$SERVICE_URI" info >/dev/null 2>&1
}

service_state() {
	if service_is_running; then
		if ! socket_exists; then
			echo "missing_socket"
			return 2
		fi

		if service_healthy; then
			echo "up"
			return 0
		fi

		echo "stale_socket"
		return 3
	fi

	if socket_exists; then
		echo "stale_socket"
		return 3
	fi

	echo "down_service"
	return 4
}

report_state() {
	local state pid
	state="$(service_state)"
	read -r pid <"$SERVICE_PIDFILE" 2>/dev/null || pid=""

	case "$state" in
		up)
			echo "service=up socket=ready uri=$SERVICE_URI pid=${pid:-unknown}"
			return 0
			;;
		missing_socket)
			echo "service=degraded state=missing_socket detail=process_running_socket_absent pid=${pid:-unknown}"
			return 2
			;;
		stale_socket)
			echo "service=degraded state=stale_socket detail=socket_present_api_unavailable pid=${pid:-none}"
			return 3
			;;
		*)
			echo "service=down state=down_service detail=process_not_running_socket_absent"
			return 4
			;;
	esac
}

probe() {
	report_state
}

status() {
	report_state
}

start_service() {
	procd_open_instance
	procd_set_param command /bin/sh -c "echo \$\$ > '$SERVICE_PIDFILE'; exec '$SERVICE_BIN' system service --time 0 '$SERVICE_URI'"
	procd_set_param respawn 5 10 0
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance

	if [ -x "$RECONCILE_HELPER" ]; then
		"$RECONCILE_HELPER" --wait-service --source service-start &
	fi
}

stop_service() {
	rm -f "$SERVICE_PIDFILE"
}
